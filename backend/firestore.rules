rules_version = '2';

// All reads/writes to the OTP and reset-token collections happen ONLY
// from the Cloud Functions (using the Admin SDK, which bypasses these
// rules entirely). Nothing in this app should ever read/write Firestore
// directly from the Flutter client, so we deny all direct client access.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
